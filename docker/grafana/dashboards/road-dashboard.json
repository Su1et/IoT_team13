      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT road_state, COUNT(*) AS count FROM processed_agent_data WHERE $__timeFilter(timestamp) GROUP BY road_state ORDER BY count DESC",
          "refId": "A"
