      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, severity FROM processed_agent_data WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Speed & RPM Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, speed FROM processed_agent_data WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "Speed"
        },
        {
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, rpm / 100 AS rpm_scaled FROM processed_agent_data WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "RPM"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Accelerometer Activity (Vibration Intensity)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, SQRT(x*x + y*y + z*z) AS vibration FROM processed_agent_data WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 1, "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Incidents by Hour of Day",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT EXTRACT(HOUR FROM timestamp) AS hour, COUNT(*) AS incidents FROM processed_agent_data WHERE road_state != 'normal' AND $__timeFilter(timestamp) GROUP BY hour ORDER BY hour",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "hour"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Recent Incidents Log",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT timestamp AS time, road_state, ROUND(severity::numeric, 2) AS severity, ROUND(speed::numeric, 1) AS speed_kmh, ROUND(latitude::numeric, 5) AS lat, ROUND(longitude::numeric, 5) AS lon FROM processed_agent_data WHERE road_state != 'normal' AND $__timeFilter(timestamp) ORDER BY timestamp DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
